# Test-mode Supabase config (loaded by Vite/vitest in `mode: test`).
#
# These exist ONLY so `createClient()` in services/api.ts doesn't throw
# "supabaseUrl is required" when the suite is imported in an environment with no
# .env.local — i.e. CI. They are NOT secrets: a fake project ref + fake anon key.
# Every test mocks its network I/O, so no request ever reaches this URL.
#
# Local dev is unaffected: Vite's env precedence is
# `.env.test.local` > `.env.local` > `.env.test` > `.env`, so a developer's
# real .env.local overrides these when they run `npm test`.
VITE_SUPABASE_URL=https://ci-placeholder.supabase.co
VITE_SUPABASE_ANON_KEY=ci-placeholder-anon-key
