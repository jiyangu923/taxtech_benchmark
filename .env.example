# ─── Supabase (required for production) ─────────────────────────────────────
# Get these from https://supabase.com → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Google OAuth (required for real Google sign-in) ─────────────────────────
# Create at https://console.cloud.google.com → APIs & Services → Credentials
# Add authorized redirect URIs: https://your-project-ref.supabase.co/auth/v1/callback
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# ─── Gemini AI (required for Benchmark Intelligence) ─────────────────────────
# Get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...
